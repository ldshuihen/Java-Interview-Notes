ked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":2,"numToAttrib":{"0":["author","7324132472265359363"],"1":["textHighlight","rgb(216,57,49)"]}},"initialAttributedTexts":{"attribs":{"0":"*0*1+4*0+1l"},"text":{"0":"内存溢出指的是内存中某一块区域的使用量超过了允许使用的最大值，从而使用内存时因空间不足而失败，虚拟机一般会抛出指定的错误。"}}},"align":"","folded":false}},"QCv4d1ETpo6EKVxx9uPczstmnBg":{"id":"QCv4d1ETpo6EKVxx9uPczstmnBg","version":2,"data":{"type":"code","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":3,"numToAttrib":{"0":["author","7324132472265359363"],"1":["bold","true"],"2":["italic","true"]}},"initialAttributedTexts":{"attribs":{"0":"*0*1+8*0|2+8*0*1+7*0|1+z*0*1+7*0|2+w*0*1+7*0|2+m*0*2+3*0|1+1*0*2+1l*0|1+1*0*2+3*0|1+1*0*1+d*0+e*0*1+8*0|1+e*0+4*0*1+j*0+k*0*1+7*0|1+e*0+u*0*1+4*0|1+h*0+8*0*1+4*0|1+b*0+8*0*1+6*0+1*0*1+4*0|1+4*0+q*0*1+8*0|1+9*0+12*0*1+4*0|1+g*0+1y*0*1+4*0|1+1*0*1+k*0+2*0*1+i*0+2*0*1+4*0|1+3*0+c*0*1+4*0|5+4c*0+1"},"text":{"0":"package q1oom;\n\nimport net.bytebuddy.jar.asm.ClassWriter;\nimport net.bytebuddy.jar.asm.Opcodes;\n\nimport java.io.IOException;\n\n/**\n * JDK8 -XX:MaxMetaspaceSize\u003d20m JDK7 -XX:MaxPermSize\u003d20m\n */\npublic class MethodAreaOOM extends ClassLoader {\n    public static void main(String[] args) throws IOException {\n        MethodAreaOOM demo1 \u003d new MethodAreaOOM();\n        int count \u003d 0;\n        while (true) {\n            String name \u003d \"Class\" + count;\n            ClassWriter classWriter \u003d new ClassWriter(0);\n            classWriter.visit(Opcodes.V1_7, Opcodes.ACC_PUBLIC, name, null\n                    , \"java/lang/Object\", null);\n            byte[] bytes \u003d classWriter.toByteArray();\n            demo1.defineClass(name, bytes, 0, bytes.length);\n            System.out.println(++count);\n        }\n    }\n}"}}},"align":"","folded":false,"language":"Java","wrap":false}},"QFZ5dFx7joc7O8xkjAOccQOInZf":{"id":"QFZ5dFx7joc7O8xkjAOccQOInZf","version":37,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+1o"},"text":{"0":"只要能编译成Java字节码文件的语言，Java虚拟机都可以运行。下图是Groovy语言在Java虚拟机上成功运行的结果："}}},"align":"","folded":false}},"QGDYd8miqoUz6jx9GvacxZdNnef":{"id":"QGDYd8miqoUz6jx9GvacxZdNnef","version":1,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+1d"},"text":{"0":"为了支持Java中Write Once，Run Anywhere；编写一次，到处运行的跨平台特性。"}}},"align":"","folded":false}},"QLzcdJVm6oCcKcxtdijcSMr6n1X":{"id":"QLzcdJVm6oCcKcxtdijcSMr6n1X","version":1,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":0,"numToAttrib":{}},"initialAttributedTexts":{"attribs":{"0":""},"text":{"0":""}}},"align":"","folded":false}},"QOtpdLedkoWR7ExGhe8coa6Snmh":{"id":"QOtpdLedkoWR7ExGhe8coa6Snmh","version":6,"data":{"type":"bullet","parent_id":"DhnxdeiMPo32SOxyLRocjpPZnFe","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+c"},"text":{"0":"基础篇-字节码文件的组成"}}},"align":"","folded":false,"text_indent":0}},"QSAEdquqaosQWfxzmfvckIHUnnh":{"id":"QSAEdquqaosQWfxzmfvckIHUnnh","version":2,"data":{"type":"code","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":fals