,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+o"},"text":{"0":"线程不共享 – 本地方法栈、虚拟机栈、程序计数器"}}},"align":"","folded":false}},"XO3VdYF2eoLqGyxsv3Xc5giNnwd":{"id":"XO3VdYF2eoLqGyxsv3Xc5giNnwd","version":3,"data":{"type":"image","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","align":"center","image":{"token":"G25Ob1Bt4onTUPxFkwbcEPU8npb","mimeType":"image/png","size":169026,"scale":1,"width":1239,"height":472,"name":"image.png","crop":[0,0,0,0],"rotation":0,"caption":{"text":{"apool":{"nextNum":0,"numToAttrib":null},"initialAttributedTexts":{"attribs":null,"text":null}}}},"area_comments":null}},"XRWTdr4b4opBv7xGDSOc7u4Jntd":{"id":"XRWTdr4b4opBv7xGDSOc7u4Jntd","version":25,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":2,"numToAttrib":{"0":["author","7324132472265359363"],"1":["inlineCode","true"]}},"initialAttributedTexts":{"attribs":{"0":"*0+t*0*1+3*0+e"},"text":{"0":"如下图中，iadd指令会将操作数栈上的两个数相加，为了实现i+1。最终结果也会放到操作数上。"}}},"align":"","folded":false}},"XStTdxLaUomkhOxWHyKcsHsxnbb":{"id":"XStTdxLaUomkhOxWHyKcsHsxnbb","version":6,"data":{"type":"bullet","parent_id":"SP2odf3b8ozehSxP66xcMsJCn3f","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+9"},"text":{"0":"基础篇-程序计数器"}}},"align":"","folded":false,"text_indent":0}},"XWw6dHRoxo0oCLxqjPecT1FMnYg":{"id":"XWw6dHRoxo0oCLxqjPecT1FMnYg","version":2,"data":{"type":"bullet","parent_id":"SP2odf3b8ozehSxP66xcMsJCn3f","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["aut