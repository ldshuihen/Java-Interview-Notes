ren":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+6"},"text":{"0":"元空间溢出："}}},"align":"","folded":false}},"Qf8eddUADoTW2nxAjZacjMZRn0e":{"id":"Qf8eddUADoTW2nxAjZacjMZRn0e","version":2,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+34"},"text":{"0":"直接内存并不在《Java虚拟机规范》中存在，所以并不属于Java运行时的内存区域。在 JDK 1.4 中引入了 NIO 机制，由操作系统直接管理这部分内容，主要为了提升读写数据的性能。在网络编程框架如Netty中被大量使用。"}}},"align":"","folded":false}},"Qhwldk0yToF8XbxrIgNc6XjMnCc":{"id":"Qhwldk0yToF8XbxrIgNc6XjMnCc","version":3,"data":{"type":"image","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","align":"center","image":{"token":"JFjpbA02aopXdyxmoOxcIDZdntb","mimeType":"image/png","size":28240,"scale":1,"width":1130,"height":192,"name":"image.png","crop":[0,0,0,0],"rotation":0,"caption":{"text":{"apool":{"nextNum":0,"numToAttrib":null},"initialAttributedTexts":{"attribs":null,"text":null}}}},"area_comments":null}},"QpHfdg1ZLoz364xMLXXc3BKznMc":{"id":"QpHfdg1ZLoz364xMLXXc3BKznMc","version":3,"data":{"type":"image","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","align":"center","image":{"token":"Kbo6bW9WJoKsYOxOYtfcQzwNnPf","mimeType":"image/png","size":23337,"scale":1,"width":1049,"height":162,"name":"image.png","crop":[0,0,0,0],"rotation":0,"caption":{"text":{"apool":{"nextNum":0,"numToAttrib":null},"initialAttributedTexts":{"attribs":null,"text":null}}}},"area_comments":null}},"Qu0Kdp202oxxzgxaFrmc63lAnre":{"id":"Qu0Kdp202oxxzgxaFrmc63lAnre","version":2,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","commen