ncTBi0nof":{"id":"Nq71djvO1oA7QqxzEkncTBi0nof","version":2,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+11"},"text":{"0":"3、JVM组成分为类加载子系统、运行时数据区、执行引擎、本地接口这四部分。"}}},"align":"","folded":false}},"Nt8GdwX1Zofhe9xSPNucN2Vxn5g":{"id":"Nt8GdwX1Zofhe9xSPNucN2Vxn5g","version":2,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+1s"},"text":{"0":"1、JVM 指的是Java虚拟机，本质上是一个运行在计算机上的程序，他的职责是运行Java字节码文件，作用是为了支持跨平台特性。"}}},"align":"","folded":false}},"O3nJdP2rHoZNdNxT2wJcH6pUn5f":{"id":"O3nJdP2rHoZNdNxT2wJcH6pUn5f","version":3,"data":{"type":"code","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":3,"numToAttrib":{"0":["author","7324132472265359363"],"1":["bold","true"],"2":["italic","true"]}},"initialAttributedTexts":{"attribs":{"0":"*0*1+8*0|2+8*0*2+k*0|1+1*0*1+d*0|1+b*0+4*0*1+j*0|1+m*0+8*0*1+5*0|2+11*0+o*0*1+4*0|3+11*0+8*0*1+5*0|1+y*0+r*0*1+8*0+i*0*1+4*0|3+a*0+4*0*1+b*0+5*0*1+4*0+2*0*1+4*0|1+4*0+8*0*1+7*0|3+e*0+4*0*1+b*0|1+b*0+8*0*1+4*0|1+9*0+8*0*1+4*0+1*0*1+4*0|3+1y*0+8*0*1+7*0|2+b*0+1"},"text":{"0":"package q1jvm;\n\n//-Xint 禁止JIT即时编译器优化\npublic class C03Usage {\n    public static void main(String[] args) {\n        long start \u003d System.currentTimeMillis();\n\n        C03Usage test \u003d new C03Usage();\n        test.jitTest();\n\n        long end \u003d System.currentTimeMillis();\n        System.out.println(\"执行耗时:\" + (end - start) + \"ms\");\n    }\n\n    public int add (int a,int b){\n        return a + b;\n    }\n\n    public int jitTest(){\n        int sum \u003d 0;\n        for (int i \u003d 0; i \u003c 10000000; i++) {\n            sum \u003d add(sum,100);\n        }\n        return sum;\n    }\n}"}}},"align":"","folded":false,"language":"Java","wrap":false}},"O4eEdqLeVoChLIxgmsgcz38enzf":{"id":"O4eEdqLeVoChLIxgmsgcz38enzf","version":5,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":1,"numToAttrib":{"0":["author","7324132472265359363"]}},"initialAttributedTexts":{"attribs":{"0":"*0+1a"},"text":{"0":"魔数、字节码文件对应的Java版本号、访问标识(public final等等)、父类和接口。"}}},"align":"","folded":false}},"OOI1dTWm3olYjfxUnZZcBmtwn0V":{"id":"OOI1dTWm3olYjfxUnZZcBmtwn0V","version":2,"data":{"type":"code","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7324132472265359363","children":[],"text":{"apool":{"nextNum":3,"numToAttrib":{"0":["author","7324132472265359363"],"1":["bold","true"],"2":["italic","true"]}},"initialAttributedTexts":{"attribs":{"0":"*0*1+8*0|3+9*0*2+3*0|1+1*0*2+p*0|1+1*0*2+3*0|1+1*0*1+d*0|1+b*0+4*0*1+j*0|4+1e*0+4*0*1+i*0|2+c*0+4*0*2+a*0|1+1*0*2+4*0*1+j*0|1+e*0+8*0*1+5*0|4+2d*0+1"},"text":{"0":"package q1oom;\n\n\n/**\n * -Xss180k 每个线程栈内存最大180k\n */\npublic class StackOOM {\n    public static void main(String[] args) {\n        recursion();\n    }\n\n    public static int count \u003d 0;\n\n    //递归方法调用自己\n    public static void recursion() {\n        long a,b,c,d,f,g,h,i,j,k;\n        System.out.println(++count);\n        recursion();\n    }\n}"}}},"align":"","folded":false,"language":"Java","wrap":false}},"OSHpd1lwQolIFjxVpB5ceY9in0d":{"id":"OSHpd1lwQolIFjxVpB5ceY9in0d","version":2,"data":{"type":"text","parent_id":"MM9DdW46losUbaxial3cQcexn3C","comments":[],"revisions":null,"locked":false,"hidden":false,"author":"7