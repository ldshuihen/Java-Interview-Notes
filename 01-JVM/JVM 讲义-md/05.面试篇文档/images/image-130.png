eout": 2000, "local_merge_by_appending": false, "chat_search_show_qa_entrance_min_request_interval": 5000, "qa_search_section_debounce_time": 100, "search_answer_card_default_source_types": [2], "myai_search_section_request_timeout": 20000},"base_dashboard_share_extension_white_list":["replit_3eba750a1c2363e4", "replit_3eb7b033c03423e3", "replit_3eb62934da8e63e6", "replit_3ebebc853c36e3e6", "replit_3e7d89b688bce3e5", "replit_3e5ca24f24eae3fb", "replit_3e8b2c23ba26a3e6", "replit_3e854694f03923fb", "replit_3ed4d0c6270fe3e3", "replit_3ebebcd44aece3e6", "replit_3eba77af93a6e3e6", "replit_3eb8e76aa026e3e3", "replit_3eb4d5cdae77a3e3", "replit_3e902deb3df723e3", "replit_3e7362f3406fe3e4", "replit_3e6b095beceb63e6"],"ccm_bitable_downgrade_starling":{"overseaHost": "https://starling-oversea.byteoversea.com", "cnHost": "https://starling.zijieapi.com", "apiKey": "6fba9ba0b72b11eca4cfef4c332413af"},"docx_clientvar_fetch_slice_config":{"preFetch": true, "concurrency": 3, "noWorker": false},"ccm_mention_config":{"authorMaxCount": 99},"ccm_docx_ai_quick_action":{"language": "zh-Hans", "actions": [{"sort": 4, "title": "总结会议决策", "id": "summary_meeting_decision", "tag": "meeting_notes", "type": "meeting_notes_personal_summary", "user_prompt": "总结会议里的关键决策。要求：1. 只总结最关键的会议决策，不总结讨论过程，不总结细枝末节，不总结单纯的工作内容汇报或分享； 2. 以列表的形式总结关键决策，列表的每一项尽量控制在 60 字以内，回答直接以列表开头，不需要有铺垫的信息； 3. 务必保证结论的正确性，会议中间产生的结论可能随后被推翻，注意识别最终决策； 4. 会议结论的表述需要清晰易懂，让没参会的人也能理解，对于多主题的会议，写清楚决策是关于哪个主题的； 5. 如会中无关键决策则向用户说明，分享类会议通常无关键决策，此时简要总结会议关键内容，篇幅不要过长。", "icon": "🔖"}, {"title": "总结发言人的主要观点", "id": "summary_speakers_content", "tag": "meeting_notes", "type": "meeting_notes_decision", "user_prompt": "总结会议里的发言人观点。要求：1. 只总结最主要的观点，不总结细枝末节，注意发言人的询问不算做观点；2. 对于每个发言人的观点总结，先加粗展示名字，再以列表的形式呈现每一项观点，注意表达精简；3. 不需要有任何铺垫信息，直接输出总结；4. 请勿对未发言的用户做总结；5. 不需要输出辅助信息；6. 参考智能纪要或文字记录文档作答", "icon": "📌"}, {"title": "总结{{name}}的发言", "id": "summary_special_speaker_content", "tag": "meeting_notes", "type": "meeting_notes_remarks", "user_prompt": "总结{{name}}的发言", "icon": "✍️"}, {"title": "总结关于“{{topic}}”的讨论", "id": "summary_special_topic", "tag": "meeting_notes", "type": "meeting_notes_topic", "user_prompt": "总结关于“{{topic}}”的讨论", "icon": "🧾"}, {"tag": "headerV2", "type": "summarize", "llpp_info": {"doubao": {"id": "ccm.docx.summarize"}}, "icon": "EditDiscriptionOutlined", "title": "总结全文"}, {"prompt_abbr_i18n_text": "续写", "title": "续写", "tag": "continue_writing", "type": "continue_writing", "llpp_info": {"doubao": {"id": "ccm.docx.continue_writing"}}, "icon": "CcmEditContinueOutlined"}, {"tag": "headerV2", "type": "explain_key_points", "llpp_info": {"doubao": {"id": "ccm.docx.conclusion"}}, "icon": "QuestionsAndAnswersOutlined", "title": "关键问题及答案"}, {"tag": "understanding", "prompt_abbr_i18n_text": "总结", "ai_block_type": "ai_edit_discription", "title": "总结", "llpp_info": {"doubao": {"id": "ccm.docx.summarize"}}, "ai_block": true, "type": "summarize", "id": "7252654608886005764", "ai_block_display_content": "总结全文", "icon": "EditDiscriptionOutlined"}, {"tag": "understanding", "prompt_abbr_i18n_text": "提取待办", "ai_block_type": "ai_todo", "title": "提取待办", "llpp_info": {"doubao": {"id": "ccm.docx.find_todo"}}, "ai_block": true, "type": "find_action_items", "id": "7252655655341670404", "ai_block_display_content": "提取全文中的待办事项", "icon": "TodoOutlined"}, {"prompt_abbr_i18n_text": "润色", "title": "润色", "tag": "revise", "type": "improve_writing", "llpp_info": {"doubao": {"id": "ccm.docx.improve_writing"}}, "icon": "SlidesAnimationOutlined"}, {"tag": "understanding", "type": "translate", "id": "7252656734165417985", "llpp_info": {"doubao": {"id": "ccm.docx.translate"}}, "title": "翻译为"}, {"prompt_abbr_i18n_text": "润色", "title": "润色", "tag": "revise", "type": "change_tone", "ai_revision": true, "llpp_info": {"doubao": {"id": "ccm.docx.change_tone"}}}, {"title": "文档大纲", "tag": "template", "template": "写一篇文档大纲，主题是：", "type": "draft", "sub_type": "draft_outline", "llpp_info": {"doubao": {"id": "ccm.docx.generate_outline"}}, "icon": "CcmEditContinueO